# Fine-grained PAT scoped to this repo, with read/write on Contents, Issues,
# Pull requests, Metadata. Create at https://github.com/settings/personal-access-tokens
GITHUB_TOKEN=

# owner/name of the repo the orchestrator is responsible for.
REPO=geserdugarov/agent-orchestrator-study

# Polling interval for the main loop, seconds.
POLL_INTERVAL=60

# Hard wall-clock cap per agent invocation, seconds.
AGENT_TIMEOUT=1800

# GitHub login the orchestrator @-mentions when it needs human attention.
HITL_HANDLE=geserdugarov

# Path to the codex CLI. Override only if not on $PATH.
CODEX_BIN=codex

# Path to the claude CLI. Override only if not on $PATH.
CLAUDE_BIN=claude

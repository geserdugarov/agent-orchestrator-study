# GITHUB_TOKEN is intentionally NOT loaded from this file. The implementer
# agent runs in a sibling worktree with sandbox bypass and can read anything
# under REPO_ROOT, so a PAT here would be recoverable via a prompt injection.
# Provide the token via one of:
#   * Export GITHUB_TOKEN in the orchestrator's launch environment, or
#   * Write it to ~/.config/podlodka-ai-club/spark-gap/token (chmod 600;
#     path is derived from REPO).
# Override the file path with ORCHESTRATOR_TOKEN_FILE if you want a different
# location -- pick a path the agent worktree cannot reach via known relatives.
# Fine-grained PAT scopes: read/write on Contents, Issues, Pull requests,
# Metadata. Create at https://github.com/settings/personal-access-tokens

# owner/name of the repo the orchestrator is responsible for.
REPO=podlodka-ai-club/spark-gap

# Polling interval for the main loop, seconds.
POLL_INTERVAL=60

# Hard wall-clock cap per agent invocation, seconds.
AGENT_TIMEOUT=1800

# Hard wall-clock cap for the codex review pass, seconds. Defaults to AGENT_TIMEOUT.
REVIEW_TIMEOUT=1800

# How many review/fix iterations to attempt before parking on awaiting_human.
MAX_REVIEW_ROUNDS=3

# Cap on how many fresh implementing-codex spawns one issue can consume within
# a 24h window opened at the first counted attempt; the window resets once 24h
# has elapsed. Resumes on human reply do NOT count against the budget.
# 0 means unbounded.
MAX_RETRIES_PER_DAY=3

# Comma-separated GitHub logins the orchestrator @-mentions when it needs human attention.
HITL_HANDLE=geserdugarov,and-semakin,garudainfo55

# Which backend implements vs. reviews. Two values: codex, claude.
# Default split: claude implements, codex reviews. Anything else aborts at
# startup so a typo cannot silently fall back. The dev backend for an
# in-flight issue is locked to whichever wrote `dev_session_id` for it; only
# fresh issues honor a flipped DEV_AGENT.
DEV_AGENT=claude
REVIEW_AGENT=codex

# Path to the codex CLI. Override only if not on $PATH.
CODEX_BIN=codex

# Path to the claude CLI. Override only if not on $PATH.
CLAUDE_BIN=claude

# git identity injected into each codex spawn via GIT_AUTHOR_*/GIT_COMMITTER_*
# env vars, so agent commits are attributable to the orchestrator rather than
# the host's git config. The default email uses GitHub's noreply form so it
# won't bounce and won't link to any real user account.
# AGENT_GIT_NAME=agent-orchestrator
# AGENT_GIT_EMAIL=agent-orchestrator@users.noreply.github.com
